# =====================================================================
# SWEEPR ENVIRONMENT VARIABLES
# =====================================================================
# ⚠️  VITE_ prefix = exposed to the browser bundle. NEVER put secrets here.
# ⚠️  Non-VITE_ vars = server-side only (Cloudflare Worker secrets).
#     Set them with: wrangler secret put VARIABLE_NAME
# =====================================================================

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Mapbox (customer address search)
VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxx

# Stripe (checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# App URLs
VITE_CUSTOMER_URL=https://app.sweep-r.com
VITE_CLEANER_URL=https://clean.sweep-r.com
VITE_MARKETING_URL=https://sweep-r.com

# PostHog
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_DASHBOARD_URL=

# PostHog (server-side, Worker secret)
POSTHOG_KEY=phc_your_key_here

# API URL
VITE_API_URL=http://localhost:8787

# ─── Cloudflare Worker Secrets (set via: wrangler secret put <NAME>) ──────────
# Never put these in .env files or commit them to the repo.

# Required in production — 32+ char random string for AES-GCM access code encryption.
# Generate: openssl rand -hex 32
# ACCESS_CODE_ENCRYPTION_KEY=<set via wrangler secret>

# Clerk server-side key (Workers runtime)
# CLERK_SECRET_KEY=<set via wrangler secret>

# Stripe
# STRIPE_SECRET_KEY=<set via wrangler secret>
# STRIPE_WEBHOOK_SECRET=<set via wrangler secret>

# Neon database URL
# DATABASE_URL=<set via wrangler secret>

# MailerSend
# MAILERSEND_API_KEY=<set via wrangler secret>

# Cloudflare R2
# R2_ACCOUNT_ID=<set via wrangler secret>
# R2_ACCESS_KEY_ID=<set via wrangler secret>
# R2_SECRET_ACCESS_KEY=<set via wrangler secret>
# R2_BUCKET=sweepr-uploads
# R2_PUBLIC_URL=https://cdn.getsweepr.com

# App URLs (wrangler.toml [vars])
# ADMIN_URL=https://admin.getsweepr.com
# CLEANER_APP_URL=https://clean.getsweepr.com
# CUSTOMER_URL=https://app.getsweepr.com
