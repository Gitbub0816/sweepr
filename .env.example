# =====================================================================
# SWEEPR ENVIRONMENT VARIABLES
# =====================================================================
# ⚠️  VITE_ prefix = exposed to the browser bundle. NEVER put secrets here.
# ⚠️  Non-VITE_ vars = server-side only (Cloudflare Worker secrets).
#     Set them with: wrangler secret put VARIABLE_NAME
# =====================================================================

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Mapbox (customer address search)
VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxx

# Stripe (checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# App URLs
VITE_CUSTOMER_URL=https://app.sweep-r.com
VITE_CLEANER_URL=https://clean.sweep-r.com
VITE_MARKETING_URL=https://sweep-r.com

# PostHog
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_DASHBOARD_URL=

# PostHog (server-side, Worker secret)
POSTHOG_KEY=phc_your_key_here

# API URL
VITE_API_URL=http://localhost:8787
